{
  "name": "protonmail-api-client",
  "version": "1.1.2",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "pm": "./bin/pm.js"
  },
  "type": "module",
  "files": [
    "bin/",
    "examples/",
    "src/",
    "scripts/",
    "README.md",
    "DEBUG.md",
    "CHANGELOG.md",
    "docs/"
  ],
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "ci:offline": "pnpm typecheck && pnpm test:unit && npm pack --dry-run",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "test": "pnpm test:unit",
    "test:unit": "node --test \"test/*.test.js\"",
    "test:live": "PROTONMAIL_LIVE_TEST=1 node --test \"test/live/**/*.test.js\"",
    "typecheck": "tsc --noEmit",
    "debug:login": "node scripts/debug-login.mjs",
    "login:probe": "node scripts/probe-login-state.mjs",
    "session:capture": "node scripts/capture-session.mjs",
    "session:cache": "node scripts/session-cache.mjs",
    "session:secret": "node scripts/set-session-secret.mjs"
  },
  "dependencies": {
    "openpgp": "^6.3.0",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.6.2",
    "playwright": "^1.58.2",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  }
}
