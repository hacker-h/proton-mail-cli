{
  "name": "proton-mail-cli",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "pm": "./bin/pm.js"
  },
  "type": "module",
  "files": [
    "bin/",
    "dist/",
    "examples/",
    "src/",
    "scripts/",
    "SECURITY.md",
    "README.md",
    "DEBUG.md",
    "CHANGELOG.md",
    "docs/"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "build:types": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.types.json",
    "ci:offline": "pnpm typecheck && pnpm test:unit && pnpm test:package && npm pack --dry-run",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "release:asset-smoke": "node scripts/release-asset-smoke.mjs",
    "test": "pnpm test:unit",
    "test:unit": "node --test \"test/*.test.js\"",
    "test:package": "node --test \"test/package/*.test.js\"",
    "test:live": "PROTONMAIL_LIVE_TEST=1 node --test \"test/live/**/*.test.js\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tools.json",
    "prepack": "pnpm build:types",
    "env:check": "node scripts/check-env-docs.mjs",
    "debug:login": "node scripts/debug-login.mjs",
    "login:probe": "node scripts/probe-login-state.mjs",
    "session:capture": "node scripts/capture-session.mjs",
    "session:cache": "node scripts/session-cache.mjs",
    "session:secret": "node scripts/set-session-secret.mjs"
  },
  "dependencies": {
    "openpgp": "^6.3.0",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.6.2",
    "playwright": "^1.58.2",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  }
}
